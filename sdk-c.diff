+ *         {@link #CAMERA_SERVICE_FATAL_ERROR} if camera service fails
+ * @since 24
+ */
+Camera_ErrorCode OH_CameraDevice_GetMinimumFocusDistance(const Camera_Device* camera, float* minimumFocusDistance);
